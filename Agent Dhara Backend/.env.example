## Copy to .env (do not commit) and fill values.
## Windows PowerShell alternative:
##   setx AZURE_SQL_SERVER "..."
##   setx AZURE_SQL_DATABASE "..."
##   setx AZURE_SQL_USERNAME "..."
##   setx AZURE_SQL_PASSWORD "..."
##   setx AZURE_STORAGE_ACCOUNT_NAME "..."
##   setx AZURE_STORAGE_ACCOUNT_KEY "..."
##   setx AZURE_ASSESSMENT_CONTAINER "assessment"
##   setx AZURE_OUTPUT_CONTAINER "output"

AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_USERNAME=
AZURE_SQL_PASSWORD=

# Blob auth option A (recommended here): account_name/account_key
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# Blob auth option B: connection string (if used, can omit account key/name)
AZURE_STORAGE_CONNECTION_STRING=

# Container names (you can keep defaults)
AZURE_ASSESSMENT_CONTAINER=assessment
AZURE_OUTPUT_CONTAINER=output

# FastAPI backend auth (required in production)
BACKEND_AUTH_TOKEN=
# Comma-separated frontend origins, e.g. http://localhost:3000,https://yourdomain.com
CORS_ALLOW_ORIGINS=http://localhost:3000
# Basic per-IP rate limit
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO

# ── LangSmith tracing (optional — leave blank to disable) ───────────────────
# Get your API key at: https://smith.langchain.com → Settings → API Keys
# Set LANGCHAIN_TRACING_V2=true to activate. If blank/false, tracing is a no-op.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agent-dhara
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
