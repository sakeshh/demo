# Copy to .env or set in your shell / Docker / Azure App Settings.
# Credentials belong in config/sources.yaml (or sources_azure_env.yaml) — not here.

# Required for MCP stdio servers and InProcessMCPBridge to find the repo
AGENT_DHARA_PROJECT_ROOT=C:\path\to\Agent Dhara Backend

# Optional: override default config/sources.yaml
# AGENT_DHARA_SOURCES_PATH=config/sources_azure_env.yaml

# Optional: REST preview tool auth (mcp_tools.rest_api_json_preview)
# AGENT_DHARA_MCP_API_BEARER=
# AGENT_DHARA_MCP_API_HEADER=
